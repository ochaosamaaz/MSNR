# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Data Source API Keys
# TwelveData (free tier: 800 requests/day) - https://twelvedata.com
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Proxy (REQUIRED in Indonesia - ISP blocks all crypto exchanges)
# Options:
#   HTTP proxy:  http://127.0.0.1:7890
#   SOCKS5:      socks5://127.0.0.1:1080
#   Clash:       http://127.0.0.1:7890
#   V2Ray:       socks5://127.0.0.1:10808
# Leave empty if you have VPN running system-wide
PROXY_URL=http://127.0.0.1:7890

# Scanning Configuration
SCAN_INTERVAL_MINUTES=5

# Zone Configuration
ZONE_BUFFER_ATR_MULTIPLIER=0.1
SL_BUFFER_PIPS=7
MAX_SL_PIPS=50
MIN_RRR=1.5

# Alert Configuration
ALERTS_ENABLED=true
MIN_SCORE_ALERT=70
