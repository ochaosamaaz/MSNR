# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# TwelveData API Key (REQUIRED - used for ALL data: Forex, Metals, AND Crypto)
# Free tier: 800 requests/day, 8 requests/minute
# Sign up at: https://twelvedata.com
TWELVEDATA_API_KEY=your_twelvedata_api_key_here

# Scanning (default 30 min - saves API budget. Priority scan uses ~12 requests)
SCAN_INTERVAL_MINUTES=30

# Zone Configuration
ZONE_BUFFER_ATR_MULTIPLIER=0.1
SL_BUFFER_PIPS=7
MAX_SL_PIPS=50
MIN_RRR=1.5

# Alert Configuration
ALERTS_ENABLED=true
MIN_SCORE_ALERT=70
